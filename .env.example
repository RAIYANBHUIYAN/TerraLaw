# Required
GROQ_API_KEY=your_groq_api_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# PostgreSQL (users + chat history — required for Render/production)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vector store backend: auto | pinecone | local
VECTORSTORE_BACKEND=pinecone

# Pinecone (dense 384-dim index for all-MiniLM-L6-v2)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=terralaw-bd
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=
PINECONE_INTEGRATED=false

# Backend CORS — add your Vercel URL after deploy (comma-separated)
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://your-app.vercel.app

# Retrieval tuning
RERANK_ENABLED=true
LLM_TEMPERATURE=0.1
